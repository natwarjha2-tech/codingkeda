// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String   @default("")
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model SurveyLead {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model SurveyResponse {
  id        String   @id @default(uuid())
  email     String
  answers   Json
  result    String
  createdAt DateTime @default(now())
}

model Student {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
}
