generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  password    String
  role        String       @default("user")
  createdAt   DateTime     @default(now())
  name        String       @default("")
  avatarUrl   String?
  enrollments Enrollment[]
  progress    Progress[]
  payments    Payment[]
  student     Student?
  quizAttempts      QuizAttempt[]
  exerciseSubmissions ExerciseSubmission[]
  weeklyStreakAttempts WeeklyStreakAttempt[]
}

model Course {
  id          String       @id @default(uuid())
  title       String
  subtitle    String
  category    String
  instructor  String
  institute   String
  students    Int          @default(0)
  rating      Float        @default(0)
  totalHours  Int
  totalVideos Int
  hasCert     Boolean      @default(true)
  color       String
  icon        String
  isActive    Boolean      @default(true)
  createdBy   String?
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  modules     Module[]
  payments    Payment[]
}

model Module {
  id       String   @id @default(uuid())
  courseId String
  title    String
  order    Int
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lesson {
  id       String     @id @default(uuid())
  moduleId String
  title    String
  duration String
  videoUrl String     @default("")
  notes    String     @default("")
  isFree   Boolean    @default(false)
  order    Int
  module   Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress Progress[]
  quizzes  Quiz[]
  exercises Exercise[]

  @@index([moduleId])
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model Progress {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model SurveyLead {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model SurveyResponse {
  id        String   @id @default(uuid())
  email     String
  answers   Json
  result    String
  createdAt DateTime @default(now())
}

model Student {
  id              String   @id @default(uuid())
  userId          String   @unique
  name            String
  email           String   @unique
  phone           String?
  enrolledCourses Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Media {
  id          String    @id @default(uuid())
  title       String
  description String?
  fileName    String
  fileSize    Int
  mimeType    String
  type        MediaType
  s3Key       String    @unique
  s3Url       String
  tags        String[]
  uploadedBy  String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

model EnrollToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  courseId  String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

enum MediaType {
  VIDEO
  PDF
  IMAGE
}

model WeeklyStreak {
  id          String                @id @default(uuid())
  lessonId    String                @unique
  moduleId    String
  courseId    String
  title       String
  description String
  problem     String
  solution    String
  weekNumber  Int
  createdAt   DateTime              @default(now())
  attempts    WeeklyStreakAttempt[]

  @@index([courseId])
  @@index([moduleId])
}

model WeeklyStreakAttempt {
  id        String       @id @default(uuid())
  userId    String
  streakId  String
  answer    String
  passed    Boolean      @default(false)
  feedback  String?
  createdAt DateTime     @default(now())
  streak    WeeklyStreak @relation(fields: [streakId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([streakId])
}

model Quiz {
  id          String        @id @default(uuid())
  lessonId    String
  question    String
  options     Json
  answer      Int
  explanation String?
  order       Int           @default(0)
  lesson      Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts    QuizAttempt[]

  @@index([lessonId])
}

model Exercise {
  id          String               @id @default(uuid())
  lessonId    String
  title       String
  description String
  difficulty  String               @default("medium")
  starterCode String?
  solution    String?
  hints       Json?
  order       Int                  @default(0)
  lesson      Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions ExerciseSubmission[]

  @@index([lessonId])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  userId    String
  quizId    String
  courseId   String
  selected  Int
  correct   Boolean
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

model ExerciseSubmission {
  id          String   @id @default(uuid())
  userId      String
  exerciseId  String
  courseId     String
  code        String
  passed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  razorpayOrderId   String   @unique  // Razorpay order ID
  razorpayPaymentId String?  // Razorpay payment ID (after success)
  
  amount            Int                // Amount in smallest unit (paisa)
  status            String   @default("pending")  // pending, success, failed, refunded
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([userId, courseId, razorpayOrderId])
}
